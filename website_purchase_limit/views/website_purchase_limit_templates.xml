<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!----  Inserta el límite oculto dentro de <body>, heredando el layout principal  -->
    <template id="website_purchase_limit_template"
              inherit_id="website.layout">
        <xpath expr="//body" position="inside">
            <!-- Solo si el sitio tiene el límite activado -->
            <t t-if="website.enabled_limit">
                <input type="hidden"
                       id="website_purchase_limit_value"
                       t-att-limit="website.purchase_limit"
                       t-att-enabled="website.enabled_limit"/>
            </t>
        </xpath>
    </template>
</odoo>
