<odoo>
  <data noupdate="1">
    <record id="ir_cron_lista_precios_mensual" model="ir.cron">
      <field name="name">Actualizar lista de precios mensual</field>
      <field name="model_id" ref="base.model_res_partner"/>
      <field name="state">code</field>
      <field name="code">model.actualizar_lista_precios_mensual()</field>
      <!-- Ejecutar 1 vez al mes -->
      <field name="interval_number">1</field>
      <field name="interval_type">months</field>
      <!-- ejecuciones ilimitadas -->
      <field name="numbercall" eval="-1"/>
      <field name="active" eval="True"/>
      <!-- Opcionalmente, puedes forzar que arranque el 1er día del mes siguiente:
      <field name="nextcall" eval="'%s 00:05:00' % fields.Date.to_string(fields.Date.today().replace(day=1) + relativedelta(months=1))"/> -->
    </record>
  </data>
</odoo>
