<odoo>
  <!-- Form view: añadir pestaña “Websites” -->
  <record id="view_pricelist_form_multi_website" model="ir.ui.view">
    <field name="name">product.pricelist.form.multi.website</field>
    <field name="model">product.pricelist</field>
    <field name="inherit_id" ref="product.view_pricelist_form"/>
    <field name="arch" type="xml">
      <xpath expr="//sheet/group" position="inside">
        <group string="Websites">
          <field name="website_ids" widget="many2many_tags"/>
        </group>
      </xpath>
    </field>
  </record>

  <!-- Tree view: mostrar sitios web junto al nombre -->
  <record id="view_pricelist_tree_multi_website" model="ir.ui.view">
    <field name="name">product.pricelist.tree.multi.website</field>
    <field name="model">product.pricelist</field>
    <field name="inherit_id" ref="product.view_pricelist_tree"/>
    <field name="arch" type="xml">
      <xpath expr="//tree/field[@name='name']" position="after">
        <field name="website_ids"/>
      </xpath>
    </field>
  </record>
</odoo>
