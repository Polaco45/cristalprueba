<odoo>
  <record id="view_payment_acquirer_form_discount" model="ir.ui.view">
    <field name="name">payment.acquirer.form.discount</field>
    <field name="model">payment.acquirer</field>
    <field name="inherit_id" ref="payment.view_payment_acquirer_form"/>
    <field name="arch" type="xml">
      <xpath expr="//field[@name='website_published']" position="after">
        <field name="discount_percent"/>
      </xpath>
    </field>
  </record>
</odoo>
