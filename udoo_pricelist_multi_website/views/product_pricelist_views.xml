<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- FORMULARIO: hereda la vista de lista de precios del módulo website_sale -->
    <record id="view_pricelist_form_multi_website" model="ir.ui.view">
        <field name="name">product.pricelist.website.form.inherit</field>
        <field name="model">product.pricelist</field>
        <!-- ref correcto en Odoo 18 -->
        <field name="inherit_id" ref="website_sale.pricelist_form_view"/>
        <field name="arch" type="xml">
            <!-- Ocultar el campo legacy website_id -->
            <xpath expr="//field[@name='website_id']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <!-- Añadir el nuevo campo Many2many -->
            <xpath expr="//group" position="inside">
                <group string="Websites">
                    <field name="public_website_ids" widget="many2many_tags"/>
                </group>
            </xpath>
        </field>
    </record>

    <!-- ÁRBOL: hereda la vista árbol de listas de precios del módulo website_sale -->
    <record id="view_pricelist_tree_multi_website" model="ir.ui.view">
        <field name="name">product.pricelist.website.tree.inherit</field>
        <field name="model">product.pricelist</field>
        <!-- ref correcto en Odoo 18 -->
        <field name="inherit_id" ref="website_sale.pricelist_tree_view"/>
        <field name="arch" type="xml">
            <!-- Insertar el campo Websites después de name -->
            <xpath expr="//field[@name='name']" position="after">
                <field name="public_website_ids" widget="many2many_tags"/>
            </xpath>
            <!-- Ocultar la columna legacy website_id -->
            <xpath expr="//field[@name='website_id']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
        </field>
    </record>
</odoo>
