<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <!-- FORMULARIO: hereda la vista web_sale donde existe website_id -->
  <record id="view_pricelist_form_multi_website" model="ir.ui.view">
    <field name="name">product.pricelist.website.form.inherit</field>
    <field name="model">product.pricelist</field>
    <!-- aquí viene la vista de Website → Comercio electrónico → Formulario -->
    <field name="inherit_id" ref="website_sale.website_sale_pricelist_form_view"/>
    <field name="arch" type="xml">
      <!-- ocultar el campo legacy -->
      <xpath expr="//field[@name='website_id']" position="attributes">
        <attribute name="invisible">1</attribute>
      </xpath>
      <!-- añadir tu M2M -->
      <xpath expr="//group" position="inside">
        <group string="Websites">
          <field name="public_website_ids" widget="many2many_tags"/>
        </group>
      </xpath>
    </field>
  </record>

  <!-- ÁRBOL: hereda la vista web_sale del listado de listas de precios -->
  <record id="view_pricelist_tree_multi_website" model="ir.ui.view">
    <field name="name">product.pricelist.website.tree.inherit</field>
    <field name="model">product.pricelist</field>
    <!-- vista usada en Website → Comercio electrónico → Listas de precios -->
    <field name="inherit_id" ref="website_sale.website_sale_pricelist_tree_view"/>
    <field name="arch" type="xml">
      <!-- insertar tu campo después del nombre -->
      <xpath expr="//field[@name='name']" position="after">
        <field name="public_website_ids" widget="many2many_tags"/>
      </xpath>
      <!-- ocultar la columna legacy de Sitio web -->
      <xpath expr="//field[@name='website_id']" position="attributes">
        <attribute name="invisible">1</attribute>
      </xpath>
    </field>
  </record>

</odoo>
