<odoo>
  <!-- FORM VIEW -->
  <record id="view_pricelist_form_multi_website" model="ir.ui.view">
    <field name="name">product.pricelist.form.multi.website</field>
    <field name="model">product.pricelist</field>
    <!-- Aquí referencia la vista original en el módulo product -->
    <field name="inherit_id" ref="product.product_pricelist_form_view"/>
    <field name="arch" type="xml">
      <!-- Ocultar el campo legacy -->
      <xpath expr="//field[@name='website_id']" position="attributes">
        <attribute name="invisible">1</attribute>
      </xpath>
      <!-- Insertar Many2many para public_website_ids -->
      <xpath expr="//sheet/group" position="inside">
        <group string="Websites">
          <field name="public_website_ids" widget="many2many_tags"/>
        </group>
      </xpath>
    </field>
  </record>

  <!-- TREE VIEW -->
  <record id="view_pricelist_tree_multi_website" model="ir.ui.view">
    <field name="name">product.pricelist.tree.multi.website</field>
    <field name="model">product.pricelist</field>
    <field name="inherit_id" ref="product.product_pricelist_tree_view"/>
    <field name="arch" type="xml">
      <!-- Mostrar los sitios junto al nombre -->
      <xpath expr="//tree/field[@name='name']" position="after">
        <field name="public_website_ids"/>
      </xpath>
    </field>
  </record>
</odoo>
