<odoo>
  <record id="delivery_carrier_form_inherit_discount" model="ir.ui.view">
    <field name="name">delivery.carrier.form.discount</field>
    <field name="model">delivery.carrier</field>
    <!-- REFERENCIA CORRECTA a la vista core -->
    <field name="inherit_id" ref="delivery.view_delivery_carrier_form"/>
    <field name="arch" type="xml">
      <!-- Comprueba en Ajustes → Técnico → Vistas que exista realmente este xpath -->
      <xpath expr="//group[@name='service']" position="inside">
        <field name="discount_percent"/>
        <field name="discount_product_id"/>
      </xpath>
    </field>
  </record>
</odoo>
