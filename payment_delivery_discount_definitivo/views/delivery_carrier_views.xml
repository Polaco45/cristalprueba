<odoo>
    <record id="view_delivery_carrier_form_discount" model="ir.ui.view">
        <field name="name">delivery.carrier.form.discount</field>
        <field name="model">delivery.carrier</field>
        <field name="inherit_id" ref="delivery.delivery_carrier_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='other_info']" position="inside">
                <field name="discount_percent"/>
                <field name="discount_product_id"/>
            </xpath>
        </field>
    </record>
</odoo>
