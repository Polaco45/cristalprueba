<odoo>
  <record id="payment_provider_form_inherit_discount" model="ir.ui.view">
    <field name="name">payment.provider.form.discount</field>
    <field name="model">payment.provider</field>
    <!-- Apuntamos a la vista core de proveedores de pago -->
    <field name="inherit_id" ref="payment.view_payment_provider_form"/>
    <field name="arch" type="xml">
      <!-- Insertamos dentro del grupo de credenciales -->
      <xpath expr="//group[@name='credentials']" position="inside">
        <field name="discount_percent"/>
        <field name="discount_product_id"/>
      </xpath>
    </field>
  </record>
</odoo>
