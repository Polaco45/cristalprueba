<odoo>
  <record id="sale_order_form_inherit_discount" model="ir.ui.view">
    <field name="name">sale.order.form.discount</field>
    <field name="model">sale.order</field>
    <field name="inherit_id" ref="sale.view_order_form"/>
    <field name="arch" type="xml">
      <xpath expr="//sheet//group[@name='order_lines']" position="after">
        <group string="Descuentos">
          <field name="payment_provider_id"/>
          <field name="discount_amount"/>
        </group>
      </xpath>
    </field>
  </record>
</odoo>
