<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
    <record id="view_discuss_channel_form_chatbot_inherit"
            model="ir.ui.view">
      <!-- human-readable name -->
      <field name="name">discuss.channel.form.chatbot.inherit</field>
      <!-- the model on which this view applies -->
      <field name="model">discuss.channel</field>
      <!-- <inherit_id> tells Odoo which existing view to extend -->
      <field name="inherit_id" ref="mail.view_mail_channel_form"/>
      <!-- specify that this is a form view -->
      <field name="type">form</field>
      <field name="priority">99</field>
      <!-- arch with type="xml" contains your xpath patch -->
      <field name="arch" type="xml">
        <xpath expr="//form/sheet" position="before">
          <header>
            <div id="chatbot_toggle_container"
                 class="o_thread_header_button"/>
          </header>
        </xpath>
      </field>
    </record>
  </data>
</odoo>
