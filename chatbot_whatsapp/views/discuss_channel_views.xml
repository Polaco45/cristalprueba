<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
    <record id="view_discuss_channel_form_chatbot_inherit" model="ir.ui.view">
        <field name="name">discuss.channel.form.chatbot.inherit</field>
        <field name="model">discuss.channel</field>
        <field name="inherit_id" ref="mail.discuss_channel_view_form"/>
        <field name="type">form</field>
        <field name="priority">99</field>
        <field name="arch" type="xml">
        <xpath expr="//header" position="inside">
            <div id="chatbot_toggle_container" class="o_thread_header_button"/>
        </xpath>
        </field>
    </record>
  </data>
</odoo>