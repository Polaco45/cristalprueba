<?xml version="1.0" encoding="UTF-8"?>
<odoo>
  <data>
    <!-- Heredamos el QWeb template de la cabecera de Discuss -->
    <template id="mail_discuss_header_hola_mundo"
              inherit_id="mail.DiscussHeader"
              name="Añadir Hola Mundo en header">
      <!-- Localizamos el contenedor de iconos / botones -->
      <xpath expr="//div[contains(@class, 'o-mail-Discuss-headerActions')]" position="inside">
        <!-- Aquí agregamos nuestro texto estático -->
        <span class="o_mail_discuss_hola_mundo ms-2 me-2" t-att-title="'Hola Mundo'">
          Hola Mundo
        </span>
      </xpath>
    </template>
  </data>
</odoo>
